# Email delivery (shared across both brands)
RESEND_API_KEY=
FROM_EMAIL=Chism Brothers Leads <leads@chismbrothers.com>
INTERNAL_NOTIFICATION_EMAIL=bid@chismbrothers.com
REPLY_TO_EMAIL=bid@chismbrothers.com

# Optional generic CRM automation webhook.
# Use Zapier, Make, n8n, Pipedream, or your own endpoint.
# The payload includes entityId and brandName so you can route to the right pipeline.
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# Public company settings (shared contact details)
NEXT_PUBLIC_COMPANY_PHONE=(555) 555-5555
NEXT_PUBLIC_COMPANY_EMAIL=bid@chismbrothers.com
NEXT_PUBLIC_COMPANY_CITY=San Diego
NEXT_PUBLIC_PRIVACY_URL=https://example.com/privacy
